# Elastic Cloud - Elasticsearch Serverless
ELASTICSEARCH_URL=https://your-project.es.us-east-1.aws.elastic.cloud
KIBANA_URL=https://your-project.kb.us-east-1.aws.elastic.cloud

# Elasticsearch API Key (Base64 encoded id:api_key)
# Create at: Kibana > Stack Management > API Keys
# Required privileges: indices (logs-*, metrics-*, security-alerts-*, deployments-*, threat-intel-*, incidents-*, incident-cortex-notifications), Agent Builder
API_KEY=your_base64_encoded_api_key

# MCP API Key (for Claude Desktop integration)
# Can be the same as API_KEY if it has Agent Builder read privileges
MCP_API_KEY=your_mcp_api_key
